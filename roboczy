        help="Path to config.yaml"
    )
    parser.add_argument(
        "--build-clients",
        help="Comma-separated list of client IDs to build DBs for (overrides config)"
    )

    parser.add_argument(
        "--db-path",
        required=True,
        help="Ścieżka do wspólnej bazy SQLite"
    )


    args = parser.parse_args()

