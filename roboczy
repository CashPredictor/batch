    F365_99_STDEV_INVO_AINITIALH,
    F365_99_ILE_FAKTUR        
FROM 
    group_cust_inv_days g
    left join invo i
on 
    g.INVO_NO = i.INVO_NO
    AND g.INVO_CLNTNO = i.INVO_CLNTNO
    AND g.INVO_ADMNO = i.INVO_ADMNO 
    AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    
LEFT JOIN (
    SELECT 
        c1.*, ROWID AS rid
    FROM INVO_CLHS_JOINED_TAB c1
) c
ON c.rid = (
        SELECT rid
        FROM (
            SELECT ROWID AS rid
            FROM INVO_CLHS_JOINED_TAB c2
            WHERE 
                   c2.INVO_NO = g.INVO_NO
               AND c2.INVO_CLNTNO = g.INVO_CLNTNO
               AND c2.INVO_ADMNO = g.INVO_ADMNO
               AND c2.INVO_DEBH_NO = g.INVO_DEBH_NO
               AND c2.INVO_DEBC_NO = g.INVO_DEBC_NO
               AND c2.CLHS_CHANGED_DATETIME <= g.DZIEN
            ORDER BY c2.CLHS_CHANGED_DATETIME DESC, RANDOM()
            LIMIT 1
        ) x
    )
  
LEFT JOIN extended_grouped_client_days_tab e
ON 
    g.INVO_ADMNO = e.INVO_ADMNO
    AND g.INVO_CLNTNO = e.INVO_CLNTNO
    AND g.INVO_DEBH_NO = e.INVO_DEBH_NO
    AND (e.INVO_DEBH_NO = g.INVO_DEBH_NO AND e.INVO_DEBC_NO = g.INVO_DEBC_NO)
    AND DATE(g.DZIEN) = DATE(e.DZIEN)

-- Dołączenie danych z summary_client_days_tab
LEFT JOIN summary_client_days_tab s
ON 
    g.INVO_CLNTNO = s.INVO_CLNTNO
    AND g.INVO_DEBH_NO = s.INVO_DEBH_NO
    AND (s.INVO_DEBH_NO = g.INVO_DEBH_NO AND s.INVO_DEBC_NO = g.INVO_DEBC_NO)
    AND DATE(g.DZIEN) = DATE(s.DZIEN)

-- Dołączenie danych z statystyki_faktur
LEFT JOIN stats_pivot_view pivot
ON g.INVO_ADMNO = pivot.INVO_ADMNO
   AND g.INVO_CLNTNO = pivot.INVO_CLNTNO
   AND g.INVO_DEBH_NO = pivot.INVO_DEBH_NO
   AND (g.INVO_DEBH_NO = pivot.INVO_DEBH_NO AND g.INVO_DEBC_NO = pivot.INVO_DEBC_NO)
   AND DATE(g.DZIEN) = DATE(pivot.DZIEN)
WHERE 
                    (
                        g.INVO_DEBC_NO IS NULL
                        OR g.INVO_DEBC_NO GLOB '*[^0-9]*'
                    )"
"CREATE VIEW dcmo_view AS  
WITH maxes AS (
    SELECT
        DEBC_ADMNO,
        DEBC_NO,
        DEBC_DEBH,
        DEBC_CLNTNO,
        DCMO_YEAR,
        DCMO_MONTH,
        MAX(DCMO_ID) AS max_id
    FROM dcmo
    GROUP BY
        DEBC_ADMNO,
        DEBC_NO,
        DEBC_DEBH,
        DEBC_CLNTNO,
        DCMO_YEAR,
        DCMO_MONTH
)    
SELECT 
    d.DCMO_ID,
    d.DEBC_ADMNO,
    d.DEBC_NO,
    d.DEBC_DEBH,
    d.DEBC_CLNTNO,
    d.DCMO_YEAR,
    d.DCMO_MONTH,
    d.DCMO_PAIDAMOUNT,
    d.DCMO_PAIDAMOUNTINVDATE,
    d.DCMO_PAIDAMOUNTDUEDATE,
    d.DCMO_PAIDAMOUNTBEFOREDUEDATE,
    d.DCMO_PAIDAMOUNTAFTDUEDAT30,
    d.DCMO_PAIDAMOUNTAFTDUEDAT60,
    d.DCMO_PAIDAMOUNTAFTDUEDAT90,
    d.DCMO_PAIDAMOUNTAFTDUEDAT120,
    d.DCMO_PAIDAMOUNTAFTDUEDATG120,
    d.DCMO_PAIDNINVBEFDUEDATE,
    d.DCMO_PAIDNINVAFTDUEDATE30,
    d.DCMO_PAIDNINVAFTDUEDATE60,
    d.DCMO_PAIDNINVAFTDUEDATE90,
    d.DCMO_PAIDNINVAFTDUEDATE120,
    d.DCMO_PAIDNINVAFTDUEDATEG120,
    d.DCMO_TOTASALESDEBTNOTES,
    d.DCMO_TOTNDEBTNOTES,
    d.DCMO_TOTASALESCREDNOTES,
    d.DCMO_TOTNCREDNOTES,
    d.DCMO_AVGBALANCEOUTSTANDING,
    d.DCMO_BALANCEHI,
    d.DCMO_NDUNNINGLETTERS,
    d.DCMO_BALANCELO,
    d.DCMO_BALANCE,
    d.DCMO_NINVOICESOUTSTANDING,
    d.DCMO_PAIDAMOUNTDISPUTES,
    d.DCMO_PAIDAMOUNTPARTIALPAYM,
    d.DCMO_MONTHNUMBER,
    d.DEBC_MARKCODESPECIALACC,
    d.DEBC_BLOCKADEPERC,
    d.DEBC_CREDITLIMIT,
    CASE 
        WHEN d.DEBC_CREDITLIMITDATE IS NOT NULL THEN DATE(d.DEBC_CREDITLIMITDATE)
        ELSE NULL
    END AS DEBC_CREDITLIMITDATE,
    CASE 
        WHEN d.DEBC_INTERNALPROLONG IS NOT NULL THEN DATE(d.DEBC_INTERNALPROLONG)
        ELSE NULL
    END AS DEBC_INTERNALPROLONG,
    d.DEBC_CLTC_TEXTCODE1,
    d.DEBC_CLTC_TEXTCODE2,
    d.DEBC_CLTC_TEXTCODE3,
    d.DEBC_REINSURANCECODE,
    d.DEBC_REINSURANCELIM,
    d.DEBC_REINSURANCELIMCURR,
    CASE 
        WHEN d.DEBC_REINSURANCELIMSTART IS NOT NULL THEN DATE(d.DEBC_REINSURANCELIMSTART)
        ELSE NULL
    END AS DEBC_REINSURANCELIMSTART,
    d.DEBC_REINSURANCELIMEXPIRY,
    d.DEBC_REINSURANCEREPORTDAYS,
    CASE 
        WHEN d.DEBC_EXTERNALPROLONGCREDLIM IS NOT NULL THEN DATE(d.DEBC_EXTERNALPROLONGCREDLIM)
        ELSE NULL
    END AS DEBC_EXTERNALPROLONGCREDLIM,
    d.DEBC_REINSURANCETYPE,
    d.DEBC_MAXDAYSNEWINVOICES,
    d.DEBC_REINSURANCECONTRACT,
    CASE 
        WHEN d.DEBC_DATECHANGE IS NOT NULL THEN DATE(d.DEBC_DATECHANGE)
        ELSE NULL
    END AS DEBC_DATECHANGE
FROM dcmo d
JOIN maxes m
  ON d.DCMO_ID     = m.max_id
 AND d.DEBC_ADMNO  = m.DEBC_ADMNO
 AND d.DEBC_NO     = m.DEBC_NO
 AND d.DEBC_DEBH   = m.DEBC_DEBH
 AND d.DEBC_CLNTNO = m.DEBC_CLNTNO
 AND d.DCMO_YEAR   = m.DCMO_YEAR
 AND d.DCMO_MONTH  = m.DCMO_MONTH"
