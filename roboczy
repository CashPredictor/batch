"CREATE VIEW INVO_CLHS_JOINED AS
SELECT 
    i.*,
    c.CLHS_CHANGED_DATETIME,
    c.CLHS_DATVALID,
    c.CLHS_DATPRINTED,
    c.CLHS_LIMITOLD,
    c.CLHS_CURRENCYOLD,
    c.CLHS_LIMITNEW,
    c.CLHS_CURRENCYNEW,
    c.CLHS_TEXTCODE1,
    c.CLHS_TEXTCODE2,
    c.CLHS_TEXTCODE3,
    c.CLHS_VARIABLETEXT1,
    c.CLHS_VARIABLETEXT2,
    c.CLHS_USRID,
    c.CLHS_AUTOMATICDECISION,
    c.CLHS_NEWDEBTOR,
    c.CLHS_NEXT_CHANGED_DATETIME
FROM 
    INVO_VIEW i
LEFT JOIN (
    -- Podzapytanie do wyznaczenia najwcześniejszego kolejnego wiersza
    SELECT 
        c1.CLHS_NO,
        c1.CLHS_DEBC_NO,
        c1.CLHS_DEBH_NO,
        c1.CLHS_ADMNO,
        c1.CLHS_CLNTNO,
        c1.CLHS_CHANGED_DATETIME,
        c1.CLHS_DATVALID,
        c1.CLHS_DATPRINTED,
        c1.CLHS_LIMITOLD,
        c1.CLHS_CURRENCYOLD,
        c1.CLHS_LIMITNEW,
        c1.CLHS_CURRENCYNEW,
        c1.CLHS_TEXTCODE1,
        c1.CLHS_TEXTCODE2,
        c1.CLHS_TEXTCODE3,
        c1.CLHS_VARIABLETEXT1,
        c1.CLHS_VARIABLETEXT2,
        c1.CLHS_USRID,
        c1.CLHS_AUTOMATICDECISION,
        c1.CLHS_NEWDEBTOR,
        MIN(c2.CLHS_CHANGED_DATETIME) AS CLHS_NEXT_CHANGED_DATETIME
    FROM 
        CLHS_VIEW c1
    LEFT JOIN 
        CLHS_VIEW c2
    ON 
        c2.CLHS_ADMNO = c1.CLHS_ADMNO
        AND (c1.CLHS_DEBH_NO = c2.CLHS_DEBH_NO)
        AND (c2.CLHS_CHANGED_DATETIME > c1.CLHS_CHANGED_DATETIME)
        AND (c1.CLHS_CLNTNO = c2.CLHS_CLNTNO)
    GROUP BY 
        c1.CLHS_NO,
        c1.CLHS_DEBC_NO,
        c1.CLHS_DEBH_NO,
        c1.CLHS_ADMNO,
        c1.CLHS_CLNTNO,
        c1.CLHS_CHANGED_DATETIME,
        c1.CLHS_DATVALID,
        c1.CLHS_DATPRINTED,
        c1.CLHS_LIMITOLD,
        c1.CLHS_CURRENCYOLD,
        c1.CLHS_LIMITNEW,
        c1.CLHS_CURRENCYNEW,
        c1.CLHS_TEXTCODE1,
        c1.CLHS_TEXTCODE2,
        c1.CLHS_TEXTCODE3,
        c1.CLHS_VARIABLETEXT1,
        c1.CLHS_VARIABLETEXT2,
        c1.CLHS_USRID,
        c1.CLHS_AUTOMATICDECISION,
        c1.CLHS_NEWDEBTOR
) c
ON 
    c.CLHS_DEBH_NO = i.INVO_DEBH_NO
    AND c.CLHS_DEBC_NO = i.INVO_DEBC_NO
    AND c.CLHS_CLNTNO = i.INVO_CLNTNO
AND 
    c.CLHS_ADMNO = i.INVO_ADMNO
AND 
    (
        -- Limit rozpoczął się przed lub w trakcie życia faktury
        (CLHS_CHANGED_DATETIME <= i.INVO_FINALPAYMENTDATE or i.INVO_FINALPAYMENTDATE is null)
        AND 
        -- Limit zakończył się w trakcie życia faktury lub po nim
        (CLHS_NEXT_CHANGED_DATETIME >= i.INVO_INVDATE OR c.CLHS_NEXT_CHANGED_DATETIME IS NULL)
    )"
"CREATE VIEW clhs_view AS
SELECT 
    CLHS_NO,
    CLHS_DEBC_NO,
    CLHS_DEBH_NO,
    CLHS_ADMNO,
    CLHS_CLNTNO,
    CASE 
    WHEN CLHS_DATCHANGED IS NOT NULL AND CLHS_TIMCHANGED IS NOT NULL THEN 
        datetime(
            substr(CAST(CLHS_DATCHANGED AS TEXT), 1, 4) || '-' ||
            substr(CAST(CLHS_DATCHANGED AS TEXT), 5, 2) || '-' ||
            substr(CAST(CLHS_DATCHANGED AS TEXT), 7, 2) || ' ' ||
            CASE
                WHEN length(CAST(CLHS_TIMCHANGED AS TEXT)) = 6 THEN 
                    substr(CAST(CLHS_TIMCHANGED AS TEXT), 1, 2) || ':' || 
                    substr(CAST(CLHS_TIMCHANGED AS TEXT), 3, 2) || ':' || 
                    substr(CAST(CLHS_TIMCHANGED AS TEXT), 5, 2)
                WHEN length(CAST(CLHS_TIMCHANGED AS TEXT)) = 5 THEN 
                    '0' || substr(CAST(CLHS_TIMCHANGED AS TEXT), 1, 1) || ':' || 
                    substr(CAST(CLHS_TIMCHANGED AS TEXT), 2, 2) || ':' || 
                    substr(CAST(CLHS_TIMCHANGED AS TEXT), 4, 2)
                ELSE NULL
            END
        )
    WHEN CLHS_DATCHANGED IS NOT NULL THEN 
        datetime(substr(CAST(CLHS_DATCHANGED AS TEXT), 1, 4) || '-' ||
                 substr(CAST(CLHS_DATCHANGED AS TEXT), 5, 2) || '-' ||
                 substr(CAST(CLHS_DATCHANGED AS TEXT), 7, 2))
    ELSE NULL
END AS CLHS_CHANGED_DATETIME,
    CASE 
        WHEN CLHS_DATVALID IS NOT NULL THEN strftime('%Y-%m-%d', CLHS_DATVALID)
        ELSE NULL
    END AS CLHS_DATVALID,
    CASE 
        WHEN CLHS_DATPRINTED IS NOT NULL THEN DATE(CLHS_DATPRINTED)
        ELSE NULL
    END AS CLHS_DATPRINTED,
    CLHS_LIMITOLD,
    CLHS_CURRENCYOLD,
    CLHS_LIMITNEW,
    CLHS_CURRENCYNEW,
    CLHS_TEXTCODE1,
    CLHS_TEXTCODE2,
    CLHS_TEXTCODE3,
    CLHS_VARIABLETEXT1,
    CLHS_VARIABLETEXT2,
    CLHS_USRID,
    CLHS_AUTOMATICDECISION,
    CLHS_NEWDEBTOR
FROM clhs"
