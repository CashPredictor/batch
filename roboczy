"CREATE VIEW summary_client_days_view AS
SELECT 
    g.INVO_ADMNO,
    g.INVO_CLNTNO,
    g.INVO_DEBH_NO,
    g.INVO_DEBC_NO,
    g.DZIEN,
    g.MIESIAC,
    g.ROK,

    -- Suma zapłaconych faktur
    COALESCE((SELECT SUM(i.INVO_AINITIALH)
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO
    ), 0) AS SUMA_ZAPLACONE,

    -- Suma zapłaconych faktur
    COALESCE((SELECT SUM(i.INVO_AINITIALH) * (SUM(julianday(i.INVO_FINALPAYMENTDATE)) - SUM(julianday(i.INVO_INVDATE)))
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS SUMA_RAZY_CZAS_ZAPLACONE,

    -- Licznik zapłaconych faktur
    COALESCE((SELECT COUNT(*)
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS LICZNIK_ZAPLACONE,

    -- Suma zapłaconych przed terminem
    COALESCE((SELECT SUM(i.INVO_AINITIALH)
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE <= i.INVO_DUEDATE
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS SUMA_PRZED_TERMINEM,

    -- Licznik zapłaconych przed terminem
    COALESCE((SELECT COUNT(*)
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE <= i.INVO_DUEDATE
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS LICZNIK_PRZED_TERMINEM,

    -- Suma zapłaconych po terminie
    COALESCE((SELECT SUM(i.INVO_AINITIALH)
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE > i.INVO_DUEDATE
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS SUMA_PO_TERMINIE,

    -- Licznik zapłaconych po terminie
    COALESCE((SELECT COUNT(*)
     FROM invo_view i
     WHERE i.INVO_FINALPAYMENTDATE IS NOT NULL
       AND i.INVO_FINALPAYMENTDATE > i.INVO_DUEDATE
       AND i.INVO_FINALPAYMENTDATE < g.DZIEN
       AND i.INVO_FINALPAYMENTDATE >= DATE(g.DZIEN, 'start of month')
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS LICZNIK_PO_TERMINIE,

    -- Suma faktur wystawionych w ostatnim miesiącu
    COALESCE((SELECT SUM(i.INVO_AINITIALH)
     FROM invo_view i
     WHERE i.INVO_INVDATE >= DATE(g.DZIEN, 'start of month') 
       AND i.INVO_INVDATE < g.DZIEN
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS SUMA_WYSTAWIONYCH,

    -- Licznik faktur wystawionych w ostatnim miesiącu
    COALESCE((SELECT COUNT(*)
     FROM invo_view i
     WHERE i.INVO_INVDATE >= DATE(g.DZIEN, 'start of month') 
       AND i.INVO_INVDATE < g.DZIEN
       AND i.INVO_ADMNO = g.INVO_ADMNO
       AND i.INVO_CLNTNO = g.INVO_CLNTNO
       AND (i.INVO_DEBH_NO = g.INVO_DEBH_NO AND i.INVO_DEBC_NO = g.INVO_DEBC_NO)
    ), 0) AS LICZNIK_WYSTAWIONYCH

FROM 
    group_cust_inv_days g
GROUP BY 
    g.INVO_ADMNO,
    g.INVO_CLNTNO,
    g.INVO_DEBH_NO,
    g.INVO_DEBC_NO,
    g.DZIEN,
    g.MIESIAC,
    g.ROK"

