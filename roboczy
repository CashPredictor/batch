import yaml
import CreateDatabase

def load_config(path="config.yaml"):
    with open(path, "r", encoding="utf-8") as f:
        return yaml.safe_load(f)

def parse_client_ids(raw):
    if raw is None:
        return None
    return [int(x.strip()) for x in raw.split(",") if x.strip()]

