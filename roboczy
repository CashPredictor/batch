def create_and_import_swieta(conn, params, file_path):
    data = pd.read_excel(file_path)
    data['data'] = pd.to_datetime(data['data'], format='%d.%m.%Y')
    data.to_sql('swieta', conn, if_exists='append', index=False)

Ta funkcja nie powinna tam zostać, bo:
	•	ładuje dane zamiast tylko korzystać z configa,
	•	używa pd, a ten plik nawet nie importuje pandas,
	•	i jest częścią starej koncepcji.  ￼

Usuń ją w całości i wstaw zamiast niej:

def insert_static_swieta(conn: sqlite3.Connection, rows: list[dict] | None) -> None:
    if not rows:
        return

    cursor = conn.cursor()
    cursor.execute("DELETE FROM swieta;")

    data_to_insert = [
        (
            row.get("nazwa"),
            row.get("rodzaj"),
            row.get("data"),
            row.get("rok"),
            row.get("mies"),
            row.get("dzien"),
            row.get("dzien_tyg"),
        )
        for row in rows
    ]

    cursor.executemany(
        """
        INSERT INTO swieta (nazwa, rodzaj, data, rok, mies, dzien, dzien_tyg)
        VALUES (?, ?, ?, ?, ?, ?, ?)
        """,
        data_to_insert,
    )
    conn.commit()

