📄 queries/select_faktury.sql

WITH invo_base AS (
  SELECT
      INVO_ADMNO,
      INVO_CLNTNO,
      INVO_DEBH_NO,
      INVO_DEBC_NO,
      INVO_AINITIALH,
      INVO_INVDATE,
      CASE
        WHEN INVO_FINALPAYMENTDATE IS NOT NULL
         AND DATE(INVO_FINALPAYMENTDATE) < DATE(?)
        THEN INVO_FINALPAYMENTDATE
        ELSE NULL
      END AS INVO_FINALPAYMENTDATE,
      INVO_DUEDATE
  FROM invo_view
  WHERE INVO_ADMNO = ?
    AND INVO_CLNTNO = ?
    AND INVO_DEBH_NO = ?
    AND INVO_DEBC_NO = ?
)
SELECT *
FROM invo_base
WHERE
      (INVO_DUEDATE IS NOT NULL AND DATE(INVO_DUEDATE) BETWEEN DATE(?) AND DATE(?))
   OR (INVO_FINALPAYMENTDATE IS NOT NULL AND DATE(INVO_FINALPAYMENTDATE) BETWEEN DATE(?) AND DATE(?))

