        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_przed_terminem' THEN AVG_INVO_AINITIALH   END) AS F365_01_AVG_INVO_AINITIALH,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_przed_terminem' THEN STDEV_INVO_AINITIALH END) AS F365_01_STDEV_INVO_AINITIALH,
