        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_po_terminie' THEN STDEV_DNI_OPOZNIENIA END) AS F365_00_STDEV_DNI_OPOZNIENIA,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_po_terminie' THEN SUM_INVO_AINITIALH   END) AS F365_00_SUM_INVO_AINITIALH,
