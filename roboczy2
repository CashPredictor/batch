        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN STDEV_DNI_DO_ZAPLATY END) AS F365_99_STDEV_DNI_DO_ZAPLATY,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN AVG_DNI_OPOZNIENIA   END) AS F365_99_AVG_DNI_OPOZNIENIA,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN STDEV_DNI_OPOZNIENIA END) AS F365_99_STDEV_DNI_OPOZNIENIA,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN SUM_INVO_AINITIALH   END) AS F365_99_SUM_INVO_AINITIALH,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN AVG_INVO_AINITIALH   END) AS F365_99_AVG_INVO_AINITIALH,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN STDEV_INVO_AINITIALH END) AS F365_99_STDEV_INVO_AINITIALH,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'wszystkie_faktury' THEN ILE_FAKTUR           END) AS F365_99_ILE_FAKTUR    
    FROM 
        group_cust_inv_days g
    -- Dołączenie danych z statystyki_faktur
    LEFT JOIN statystyki_faktur stats_pivot
    ON g.INVO_ADMNO = stats_pivot.INVO_ADMNO
       AND g.INVO_CLNTNO = stats_pivot.INVO_CLNTNO
       AND g.INVO_DEBH_NO = stats_pivot.INVO_DEBH_NO
       AND (g.INVO_DEBH_NO = stats_pivot.INVO_DEBH_NO AND g.INVO_DEBC_NO = stats_pivot.INVO_DEBC_NO)
       AND DATE(g.DZIEN) = DATE(stats_pivot.DZIEN)
    WHERE {shard_condition}
    GROUP BY
        g.INVO_ADMNO,
        g.INVO_CLNTNO,
        g.INVO_DEBH_NO,
        g.INVO_DEBC_NO,
        g.DZIEN;

