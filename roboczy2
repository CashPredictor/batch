import sqlite3
import pandas as pd
import hashlib
from pathlib import Path
from collections import Counter
# ============================================================
# KONFIGURACJA
# ============================================================
BASE_DIR = Path(r"C:\Users\OE00SG\CashPredictor\dev3\databases\2026-03-02\2026-03-02")
OLD_DB = BASE_DIR / "CashPredictorT_13581 — kopia.db"
NEW_DB = BASE_DIR / "CashPredictor2.db"
CLIENT_ID = 13581
# Kolumny, które można pominąć globalnie, jeśli nie chcesz ich porównywać.
# Na start zostawiam puste. Możesz później dopisać np. INSERT_TIMESTAMP.
IGNORE_COLUMNS = {
    # "INSERT_TIMESTAMP",
    # "rowid",
}
# Mapowanie potencjalnych kolumn klienta
CLIENT_COLUMNS = [
    "INVO_CLNTNO",
    "DEBC_CLNTNO",
    "CLHS_CLNTNO",
]
# Ile przykładowych różnic pokazać
SAMPLE_DIFF_ROWS = 5
# ============================================================
# POMOCNICZE
# ============================================================
def connect(db_path: Path) -> sqlite3.Connection:
    return sqlite3.connect(str(db_path))
def get_tables(conn: sqlite3.Connection) -> list[str]:
    sql = """
        SELECT name
        FROM sqlite_master
        WHERE type = 'table'
          AND name NOT LIKE 'sqlite_%'
        ORDER BY name
    """
    return [r[0] for r in conn.execute(sql).fetchall()]
def get_columns(conn: sqlite3.Connection, table: str) -> list[str]:
    sql = f"PRAGMA table_info([{table}])"
    return [r[1] for r in conn.execute(sql).fetchall()]
def find_client_column(columns: list[str]) -> str | None:
    for col in CLIENT_COLUMNS:
        if col in columns:
            return col
    return None
def normalize_value(v):
    if pd.isna(v):
        return "<NULL>"
    if isinstance(v, bytes):
        return v.hex()
    if isinstance(v, float):
        # normalizacja floatów, żeby ograniczyć fałszywe różnice formatu
        return f"{v:.10f}".rstrip("0").rstrip(".") if "." in f"{v:.10f}" else f"{v:.10f}"
    return str(v)
def row_hash(values: tuple) -> str:
    payload = "||".join(normalize_value(v) for v in values)
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()
def load_table(
    conn: sqlite3.Connection,
    table: str,
    select_columns: list[str],
    client_id: int | None = None,
    client_column: str | None = None,
) -> pd.DataFrame:
    cols_sql = ", ".join(f"[{c}]" for c in select_columns)
    if client_id is not None and client_column is not None:
        sql = f"SELECT {cols_sql} FROM [{table}] WHERE [{client_column}] = ?"
        return pd.read_sql_query(sql, conn, params=(client_id,))
    else:
        sql = f"SELECT {cols_sql} FROM [{table}]"
        return pd.read_sql_query(sql, conn)
def compare_table(
    old_conn: sqlite3.Connection,
    new_conn: sqlite3.Connection,
    table: str,
    client_id: int,
) -> dict:
    old_cols = get_columns(old_conn, table)
    new_cols = get_columns(new_conn, table)
    new_client_col = find_client_column(new_cols)
    old_client_col = find_client_column(old_cols)
    # Pomijamy kolumny ignorowane i kolumnę klienta w nowej bazie,
    # jeśli jej nie ma w starej.
    old_cols_cmp = [c for c in old_cols if c not in IGNORE_COLUMNS]
    new_cols_cmp = [c for c in new_cols if c not in IGNORE_COLUMNS]
    if old_client_col is None and new_client_col is not None:
        new_cols_cmp = [c for c in new_cols_cmp if c != new_client_col]
    # Wspólne kolumny do porównania
    common_cols = [c for c in old_cols_cmp if c in new_cols_cmp]
    result = {
        "table": table,
        "status": None,
        "old_rows": None,
        "new_rows": None,
        "common_cols_count": len(common_cols),
        "only_in_old_cols": sorted(set(old_cols_cmp) - set(common_cols)),
        "only_in_new_cols": sorted(set(new_cols_cmp) - set(common_cols)),
        "only_in_old_rows": 0,
        "only_in_new_rows": 0,
        "samples_only_in_old": [],
        "samples_only_in_new": [],
    }
    if not common_cols:
        result["status"] = "NO_COMMON_COLUMNS"
        return result
    old_df = load_table(
        old_conn,
        table,
        select_columns=common_cols,
        client_id=client_id if old_client_col else None,
        client_column=old_client_col,
    )
    new_df = load_table(
        new_conn,
        table,
        select_columns=common_cols,
        client_id=client_id if new_client_col else None,
        client_column=new_client_col,
    )
    result["old_rows"] = len(old_df)
    result["new_rows"] = len(new_df)
    old_hashes = old_df.apply(lambda row: row_hash(tuple(row.values.tolist())), axis=1).tolist()
    new_hashes = new_df.apply(lambda row: row_hash(tuple(row.values.tolist())), axis=1).tolist()
    old_counter = Counter(old_hashes)
    new_counter = Counter(new_hashes)
    only_in_old = old_counter - new_counter
    only_in_new = new_counter - old_counter
    result["only_in_old_rows"] = sum(only_in_old.values())
    result["only_in_new_rows"] = sum(only_in_new.values())
    if result["only_in_old_rows"] == 0 and result["only_in_new_rows"] == 0:
        if result["only_in_old_cols"] or result["only_in_new_cols"]:
            result["status"] = "DATA_OK_SCHEMA_DIFF"
        else:
            result["status"] = "OK"
        return result
    result["status"] = "DATA_DIFF"
    # przykładowe wiersze różnic
    old_df = old_df.copy()
    new_df = new_df.copy()
    old_df["_hash"] = old_hashes
    new_df["_hash"] = new_hashes
    old_samples = []
    for h in list(only_in_old.keys())[:SAMPLE_DIFF_ROWS]:
        rows = old_df.loc[old_df["_hash"] == h, common_cols].head(1).to_dict(orient="records")
        old_samples.extend(rows)
    new_samples = []
    for h in list(only_in_new.keys())[:SAMPLE_DIFF_ROWS]:
        rows = new_df.loc[new_df["_hash"] == h, common_cols].head(1).to_dict(orient="records")
        new_samples.extend(rows)
    result["samples_only_in_old"] = old_samples[:SAMPLE_DIFF_ROWS]
    result["samples_only_in_new"] = new_samples[:SAMPLE_DIFF_ROWS]
    return result
def main():
    if not OLD_DB.exists():
        raise FileNotFoundError(f"Brak starej bazy: {OLD_DB}")
    if not NEW_DB.exists():
        raise FileNotFoundError(f"Brak nowej bazy: {NEW_DB}")
    old_conn = connect(OLD_DB)
    new_conn = connect(NEW_DB)
    try:
        old_tables = set(get_tables(old_conn))
        new_tables = set(get_tables(new_conn))
        common_tables = sorted(old_tables & new_tables)
        only_old_tables = sorted(old_tables - new_tables)
        only_new_tables = sorted(new_tables - old_tables)
        print("=" * 100)
        print("PORÓWNANIE BAZ")
        print("=" * 100)
        print(f"Stara baza: {OLD_DB.name}")
        print(f"Nowa baza : {NEW_DB.name}")
        print(f"Klient     : {CLIENT_ID}")
        print()
        if only_old_tables:
            print("Tabele tylko w starej bazie:")
            for t in only_old_tables:
                print(f"  - {t}")
            print()
        if only_new_tables:
            print("Tabele tylko w nowej bazie:")
            for t in only_new_tables:
                print(f"  - {t}")
            print()
        results = []
        for table in common_tables:
            try:
                res = compare_table(old_conn, new_conn, table, CLIENT_ID)
                results.append(res)
            except Exception as e:
                results.append({
                    "table": table,
                    "status": f"ERROR: {e}",
                    "old_rows": None,
                    "new_rows": None,
                    "common_cols_count": None,
                    "only_in_old_cols": [],
                    "only_in_new_cols": [],
                    "only_in_old_rows": None,
                    "only_in_new_rows": None,
                    "samples_only_in_old": [],
                    "samples_only_in_new": [],
                })
        summary_df = pd.DataFrame([{
            "table": r["table"],
            "status": r["status"],
            "old_rows": r["old_rows"],
            "new_rows": r["new_rows"],
            "common_cols_count": r["common_cols_count"],
            "only_in_old_rows": r["only_in_old_rows"],
            "only_in_new_rows": r["only_in_new_rows"],
            "only_in_old_cols_count": len(r["only_in_old_cols"]),
            "only_in_new_cols_count": len(r["only_in_new_cols"]),
        } for r in results])
        print("=" * 100)
        print("PODSUMOWANIE")
        print("=" * 100)
        print(summary_df.to_string(index=False))
        print()
        print("=" * 100)
        print("SZCZEGÓŁY RÓŻNIC")
        print("=" * 100)
        any_diff = False
        for r in results:
            if r["status"] not in {"OK", "DATA_OK_SCHEMA_DIFF"}:
                any_diff = True
                print(f"\n--- {r['table']} ---")
                print(f"Status: {r['status']}")
                print(f"old_rows={r['old_rows']}, new_rows={r['new_rows']}")
                print(f"Kolumny tylko w starej: {r['only_in_old_cols']}")
                print(f"Kolumny tylko w nowej : {r['only_in_new_cols']}")
                print(f"Wiersze tylko w starej: {r['only_in_old_rows']}")
                print(f"Wiersze tylko w nowej : {r['only_in_new_rows']}")
                if r["samples_only_in_old"]:
                    print("Przykłady wierszy tylko w starej:")
                    for x in r["samples_only_in_old"]:
                        print(x)
                if r["samples_only_in_new"]:
                    print("Przykłady wierszy tylko w nowej:")
                    for x in r["samples_only_in_new"]:
                        print(x)
        if not any_diff:
            print("Brak różnic danych poza ewentualnymi różnicami schematu.")
            print()
        # zapis raportu CSV
        report_path = BASE_DIR / f"compare_report_client_{CLIENT_ID}.csv"
        summary_df.to_csv(report_path, index=False, encoding="utf-8-sig")
        print(f"Raport CSV zapisany do: {report_path}")
    finally:
        old_conn.close()
        new_conn.close()
if __name__ == "__main__":
    main()

