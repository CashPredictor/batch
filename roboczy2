2. Indeksy tylko dla brakujących tabel

import pandas as pd

table_list_sql = ", ".join([f"'{t}'" for t in missing_tables])

df_indexes = pd.read_sql_query(f"""
WITH tables AS (
    SELECT name AS table_name
    FROM sqlite_master
    WHERE type = 'table'
      AND name NOT LIKE 'sqlite_%'
      AND name IN ({table_list_sql})
),
indexes AS (
    SELECT
        tbl_name AS table_name,
        name     AS index_name
    FROM sqlite_master
    WHERE type = 'index'
      AND name NOT LIKE 'sqlite_autoindex%'
      AND tbl_name IN ({table_list_sql})
),
index_columns AS (
    SELECT
        il.tbl_name AS table_name,
        il.name     AS index_name,
        ii.seqno    AS seq,
        ii.name     AS column_name
    FROM sqlite_master il
    JOIN pragma_index_info(il.name) ii
    WHERE il.type = 'index'
      AND il.name NOT LIKE 'sqlite_autoindex%'
      AND il.tbl_name IN ({table_list_sql})
)
SELECT
    t.table_name                       AS tabela,
    i.index_name                       AS indeks,
    group_concat(ic.column_name, ', ') AS kolumny
FROM tables t
LEFT JOIN indexes i
       ON i.table_name = t.table_name
LEFT JOIN index_columns ic
       ON ic.table_name = t.table_name
      AND ic.index_name = i.index_name
GROUP BY
    t.table_name,
    i.index_name
ORDER BY
    t.table_name,
    i.index_name;
""", conn)

df_indexes


