db_path = params["database"]

conn = sqlite3.connect(
    db_path,
    detect_types=sqlite3.PARSE_DECLTYPES | sqlite3.PARSE_COLNAMES
)
cursor = conn.cursor()

i usuń pętlę:

for client_id in client_ids:

całą logikę niżej odsuń o jeden poziom w lewo.

⸻

Jak powinien wyglądać build_client_dbs.py

Docelowo mniej więcej tak:

import argparse
import yaml
from datetime import datetime
import CreateDatabase

def load_config(path: str) -> dict:
    with open(path, "r", encoding="utf-8") as f:
        return yaml.safe_load(f)

def parse_client_ids(raw: str) -> list[int]:
    return [int(x.strip()) for x in raw.split(",") if x.strip()]

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--config", required=True)
    parser.add_argument("--t0", required=True)
    parser.add_argument("--build-clients", required=True, help="Lista klientów po przecinku")
    parser.add_argument("--db-path", required=True, help="Wspólna baza SQLite")
    args = parser.parse_args()

    cfg = load_config(args.config)
    params = cfg["first_model_params"]

    build_client_ids = parse_client_ids(args.build_clients)
    t0 = datetime.strptime(args.t0, "%Y-%m-%d")

    for client_id in build_client_ids:
        run_params = dict(params)
        run_params["train_client_id"] = client_id
        run_params["database"] = args.db_path

        print(f"[INFO] Start klienta {client_id} -> baza: {args.db_path}")

        CreateDatabase.CreateDatabase(
            params=run_params,
            t0=t0,
            create_many_dbs_from_one_excel=True,
            skip_raw_tables=False,
            build_derived=True
        )

        print(f"[OK] Klient {client_id} zakończony")

if __name__ == "__main__":
    main()


