        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_przed_terminem' THEN STDEV_DNI_DO_ZAPLATY END) AS F365_01_STDEV_DNI_DO_ZAPLATY,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_przed_terminem' THEN AVG_DNI_OPOZNIENIA   END) AS F365_01_AVG_DNI_OPOZNIENIA,
        MAX(CASE WHEN PARAM_Z_ILU_DNI = 365 AND SCENARIUSZ LIKE 'niezap_acone_przed_terminem' THEN STDEV_DNI_OPOZNIENIA END) AS F365_01_STDEV_DNI_OPOZNIENIA,
