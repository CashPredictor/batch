9. Jeśli chcesz zrobić pełne CREATE TABLE już w Pythonie

To nawet lepiej niż składanie ręcznie w Excelu.

def build_create_table_script(df_one_table):
    table_name = df_one_table['table_name'].iloc[0]
    lines = []

    for _, row in df_one_table.sort_values('cid').iterrows():
        col_def = f'{row["name"]} {row["type"]}'
        if row['notnull'] == 1:
            col_def += ' NOT NULL'
        if pd.notna(row['dflt_value']):
            col_def += f' DEFAULT {row["dflt_value"]}'
        if row['pk'] == 1:
            col_def += ' PRIMARY KEY'
        lines.append(f'    {col_def}')

    sql = f'CREATE TABLE {table_name} (\n' + ',\n'.join(lines) + '\n);'
    return sql

create_table_rows = []
for table_name, df_grp in df_table_info.groupby('table_name'):
    create_table_rows.append({
        'table_name': table_name,
        'create_table_sql': build_create_table_script(df_grp)
    })

df_create_tables = pd.DataFrame(create_table_rows)
df_create_tables

