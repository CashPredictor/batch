def generate_first_model_create_table_yaml(df, table_name="first_model_tab"):
    import pandas as pd
    col_defs = ['        RunIdentifier TEXT']
    for col in df.columns:
        if col == "RunIdentifier":
            continue
        dtype = df[col].dtype
        if pd.api.types.is_integer_dtype(dtype):
            sql_type = "INTEGER"
        elif pd.api.types.is_float_dtype(dtype):
            sql_type = "REAL"
        elif pd.api.types.is_datetime64_any_dtype(dtype):
            sql_type = "DATETIME"
        else:
            sql_type = "TEXT"
        col_defs.append(f'        {col} {sql_type}')
    sql = "  query_create_first_model_tab: |\n"
    sql += f"    CREATE TABLE IF NOT EXISTS {table_name} (\n"
    sql += ",\n".join(col_defs)
    sql += "\n    );"
    return sql

